            android:horizontalGap="0%p" android:keyWidth="15%p" android:isModifier="true"
            android:isSticky="true" android:keyEdgeFlags="right"/>
    </Row>

    <Row>
        <Key android:codes="93" android:keyIcon="@drawable/icon_empty" android:horizontalGap="3%p" android:keyEdgeFlags="left" />
