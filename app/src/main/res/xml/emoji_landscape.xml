            android:horizontalGap="0%p" android:keyWidth="15%p" android:isModifier="true"
            android:isSticky="true" android:keyEdgeFlags="right"/>
    </Row>

    <Row android:rowEdgeFlags="bottom" android:verticalGap="0%p">
        <Key android:codes="96" android:keyIcon="@drawable/icon_empty" android:horizontalGap="3%p" android:keyEdgeFlags="left" />
