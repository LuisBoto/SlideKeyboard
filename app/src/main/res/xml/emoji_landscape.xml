<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="12%p"
    android:keyHeight="14%p"
    android:horizontalGap="0px"
    android:verticalGap="10px">

    <Row android:rowEdgeFlags="top">
        <Key android:codes="87" android:keyIcon="@drawable/icon_empty" android:horizontalGap="3%p"  android:keyEdgeFlags="left" />
        <Key android:codes="88" android:keyIcon="@drawable/icon_empty" />

        <Key android:codes="76" android:keyWidth="34%p" />

        <Key android:codes="88" android:keyIcon="@drawable/icon_empty" />
